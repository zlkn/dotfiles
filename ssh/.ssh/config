Host *
    # Force to use terminal palette everywhere instead of hardcoded colors
    SetEnv SYSTEMD_COLORS=16
    SetEnv TERM=xterm

    # Make all sessions to the same host share a single connection.
    ForwardAgent yes
    ControlMaster auto
    ControlPersist 120
    ControlPath /tmp/socket-%r@%h:%p

    # Minimal config for comfortable usage
    # PermitLocalCommand yes
    # LocalCommand scp -P %p %d/.vimrc %u@%n: &>/dev/null && scp -P %p %d/.tmux.conf %u@%n: &>/dev/null

Host github.com
    HostName github.com
    IdentityFile ~/.ssh/github_ed25519
    IdentitiesOnly yes
    ControlMaster no

Host claude
    HostName 34.141.64.45

