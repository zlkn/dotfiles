# EditorConfig is awesome: https://editorconfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 4
max_line_lenghth = 120

[Makefile]
indent_style = tab

[*.{yaml,yml}]
indent_size = 2

[*.tf]
indent_size = 2

